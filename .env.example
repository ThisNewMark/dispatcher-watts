# dispatcher-watts environment variables.
#
# Copy this file to `.env` and fill in your values:
#     cp .env.example .env
#
# `.env` is gitignored and will never be committed. The CLI loads it
# automatically on startup. Real environment variables take precedence.

# --- ERCOT public API (primary data source, no row/call cap) -----------------
# Sign up at https://apiexplorer.ercot.com/ — gives you a subscription key.
# The same email/password are used for the OAuth2 ROPC token exchange.
ERCOT_API_USERNAME=
ERCOT_API_PASSWORD=
ERCOT_API_SUBSCRIPTION_KEY=

# --- gridstatus.io (legacy fallback, free tier 250 req / 500k rows per month) -
# Get a key at https://www.gridstatus.io/settings/api
GRIDSTATUS_API_KEY=
