# dispatcher-watts environment variables.
#
# Copy this file to `.env` and fill in your values:
#     cp .env.example .env
#
# `.env` is gitignored and will never be committed. The CLI loads it
# automatically on startup. Real environment variables take precedence.

# gridstatus.io API key — required to fetch ERCOT price data.
# Get one (free tier available) at: https://www.gridstatus.io/settings/api
GRIDSTATUS_API_KEY=
