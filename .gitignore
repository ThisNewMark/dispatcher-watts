# Market data — fetched locally, never committed (gridstatus row budget).
# Also covers data/live/, the live simulator's append-only capture log.
/data/

# Live paper-trading simulator state (SoC, running P&L, decision log)
/state/

# Competition SQLite database (created at the project home by default)
/competition.db

# Generated results — regenerate with `dispatcher-watts reproduce-v1`
/results/

# Local-only blog drafts (not committed to the repo)
/BLOG_DRAFT_*.md

# Local-only working notes (not committed)
/STRATEGY_IDEAS.md

# Local-only project notes (not committed)
/docs/V2_PIECES.md

# Local secrets — copy .env.example to .env and paste your key there.
# .env.example IS committed as a template; .env never is.
.env

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
build/
dist/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage*
htmlcov/

# Notebooks
.ipynb_checkpoints/

# OS / editor
.DS_Store
.idea/
.vscode/
